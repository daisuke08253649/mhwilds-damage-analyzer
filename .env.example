# supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# fastapi
NEXT_PUBLIC_API_BASE_URL=

# cloudflare_r2
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# gemini
GEMINI_API_KEY=
# 未設定時は gemini-3.1-flash-lite（本番向け、有料ティアあり・レート制限明記）。
# ローカルでの無料枠テストには gemma-4-26b-a4b-it も指定可能（無料ティア専用・レート制限は非公開）。
GEMINI_MODEL=
# Gemini OCR 1リクエストあたりのタイムアウト秒数。未設定時は45。1秒未満は起動時エラー
GEMINI_OCR_TIMEOUT_SECONDS=

OCR_BACKEND=

MAX_UPLOAD_SIZE_MB=
ALLOWED_ORIGINS=

# OCR に渡す前にフレームを縮小する最大幅（px）。未設定時は1280。正の整数のみ有効
FRAME_MAX_WIDTH=

# youtube
# Netscape 形式の Cookie ファイルを base64 エンコードした値（yt-dlp のボット対策回避用）
# base64 -w 0 cookies.txt  または  [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt"))
YOUTUBE_COOKIES_B64=